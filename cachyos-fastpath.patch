+        // -1 means "unknown"; fall back rather than pacing to zero.
+        return FALLBACK_BPS;
+      }
+      return static_cast<size_t>(mbps) * 1'000'000;
+#else
+      (void) local_address;
+      return FALLBACK_BPS;
+#endif
+    }
